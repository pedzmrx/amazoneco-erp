generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyType {
  GENERATOR // Fábricas do PIM (Ex: Samsung, Honda)
  TRANSPORTER // Empresas de Logística/Balsas
  DESTINATOR // Recicladoras/Aterros
}

enum ManifestStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Company {
  id            String   @id @default(uuid())
  name          String
  cnpj          String   @unique
  type          String
  address       String
  licenseNumber String?
  createdAt     DateTime @default(now())

  generatedManifests   Manifest[] @relation("GeneratorRelation")
  transportedManifests Manifest[] @relation("TransporterRelation")
  destinatedManifests  Manifest[] @relation("DestinatorRelation")
}

model WasteItem {
  id            String         @id @default(uuid())
  description   String
  class         String
  unit          String
  manifestItems ManifestItem[]
}

model Manifest {
  id          String         @id @default(uuid())
  status      ManifestStatus @default(PENDING)
  issuedAt    DateTime       @default(now())
  completedAt DateTime?

  generator   Company @relation("GeneratorRelation", fields: [generatorId], references: [id])
  generatorId String

  transporter   Company @relation("TransporterRelation", fields: [transporterId], references: [id])
  transporterId String

  destinator   Company @relation("DestinatorRelation", fields: [destinatorId], references: [id])
  destinatorId String

  items ManifestItem[]
}

model ManifestItem {
  id       String @id @default(uuid())
  quantity Float

  manifest   Manifest @relation(fields: [manifestId], references: [id])
  manifestId String

  wasteItem   WasteItem @relation(fields: [wasteItemId], references: [id])
  wasteItemId String
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
